{
  "description": "工数管理システム SharePoint 構造定義",
  "site": "[YOUR_SHAREPOINT_SITE_URL]",
  "lists": [
    {
      "name": "Projects",
      "displayName": "プロジェクト",
      "description": "プロジェクトマスタ。Outlookカテゴリと紐付けて工数を自動分類する。",
      "columns": [
        {
          "internalName": "Title",
          "displayName": "プロジェクト名",
          "type": "Text",
          "required": true,
          "example": "プロジェクトA"
        },
        {
          "internalName": "ProjectCode",
          "displayName": "プロジェクトコード",
          "type": "Text",
          "required": true,
          "note": "英数字・アンダースコアのみ。HTML ダッシュボード内部で集計キーとして使用。",
          "example": "proj_a"
        },
        {
          "internalName": "OutlookCategory",
          "displayName": "Outlookカテゴリ名",
          "type": "Text",
          "required": true,
          "note": "Outlookカレンダーのカテゴリ名と完全一致させる。Flow 1 がこの値でプロジェクトを自動判定する。",
          "example": "プロジェクトA"
        },
        {
          "internalName": "Color",
          "displayName": "カラー",
          "type": "Text",
          "required": true,
          "note": "HEX形式（例: #FF6384）。HTMLダッシュボードのグラフ色に使用。",
          "example": "#FF6384"
        },
        {
          "internalName": "PlannedHours",
          "displayName": "予定工数（時間）",
          "type": "Number",
          "required": false,
          "note": "年度ごとの予定工数。進捗率計算に使用。未設定の場合は進捗率を表示しない。",
          "example": 100
        },
        {
          "internalName": "IsActive",
          "displayName": "有効",
          "type": "Boolean",
          "required": true,
          "default": true,
          "note": "false にするとカテゴリマッチング対象外になる。"
        }
      ],
      "sampleData": [
        {
          "Title": "プロジェクトA",
          "ProjectCode": "proj_a",
          "OutlookCategory": "プロジェクトA",
          "Color": "#FF6384",
          "PlannedHours": 100,
          "IsActive": true
        },
        {
          "Title": "プロジェクトB",
          "ProjectCode": "proj_b",
          "OutlookCategory": "プロジェクトB",
          "Color": "#36A2EB",
          "PlannedHours": 80,
          "IsActive": true
        },
        {
          "Title": "プロジェクトC",
          "ProjectCode": "proj_c",
          "OutlookCategory": "プロジェクトC",
          "Color": "#FFCE56",
          "PlannedHours": 60,
          "IsActive": true
        }
      ]
    },
    {
      "name": "WorkHoursLog",
      "displayName": "工数ログ",
      "description": "Outlookの予定に紐づく工数記録。Power Automateが自動登録する。",
      "columns": [
        {
          "internalName": "Title",
          "displayName": "予定名",
          "type": "Text",
          "required": true,
          "note": "Outlookイベントの subject が自動入力される。"
        },
        {
          "internalName": "EventId",
          "displayName": "イベントID",
          "type": "Text",
          "required": true,
          "note": "Outlook イベントの一意 ID。重複登録防止・更新追跡に使用。"
        },
        {
          "internalName": "StartDateTime",
          "displayName": "開始日時",
          "type": "DateTime",
          "required": true,
          "note": "Outlook トリガーから取得。SharePoint は内部的に UTC で保存し、表示時にユーザーのタイムゾーンに変換する。"
        },
        {
          "internalName": "EndDateTime",
          "displayName": "終了日時",
          "type": "DateTime",
          "required": true
        },
        {
          "internalName": "DurationHours",
          "displayName": "工数（時間）",
          "type": "Number",
          "required": true,
          "note": "小数点以下2桁まで（Power Automate 側で round() する）。例: 1.5 = 1時間30分。"
        },
        {
          "internalName": "ProjectCode",
          "displayName": "プロジェクトコード",
          "type": "Text",
          "required": false,
          "note": "Projects.ProjectCode と対応。カテゴリ未設定の場合は空文字（未分類）。"
        },
        {
          "internalName": "ProjectName",
          "displayName": "プロジェクト名",
          "type": "Text",
          "required": false,
          "note": "非正規化（表示用）。登録時の Projects.Title のコピー。"
        },
        {
          "internalName": "RecordedAt",
          "displayName": "登録日時",
          "type": "DateTime",
          "required": true,
          "note": "Power Automate が utcNow() で自動設定。工数ログの作成日時（監査用）。"
        },
        {
          "internalName": "Status",
          "displayName": "ステータス",
          "type": "Choice",
          "required": true,
          "default": "Active",
          "choices": ["Active", "Cancelled"],
          "note": "Active=有効, Cancelled=予定削除により無効化。更新時は Active を維持し、LastSyncedAt で更新履歴を追跡する。ダッシュボードは Cancelled 以外を集計する。"
        },
        {
          "internalName": "LastSyncedAt",
          "displayName": "最終同期日時",
          "type": "DateTime",
          "required": false,
          "note": "Flow 1 で初回登録時、Flow 3 で更新・キャンセル時に utcNow() で設定する。"
        }
      ]
    }
  ],
  "documentLibraries": [
    {
      "name": "WorkHoursDashboard",
      "displayName": "工数ダッシュボード",
      "description": "Power AutomateがHTMLダッシュボードを保存するドキュメントライブラリ。",
      "files": [
        {
          "name": "index.html",
          "description": "工数可視化ダッシュボード。工数登録・更新・削除のたびに自動再生成される。",
          "howToView": "SharePointからダウンロードしてブラウザで開く。"
        },
        {
          "name": "_template/index.html",
          "description": "HTML テンプレート。Flow 2 がこのファイルを読み込み、データを埋め込んで index.html を生成する。"
        }
      ]
    }
  ],
  "setupSteps": [
    "1. SharePoint サイトを開く（または新規作成）",
    "2. 「サイトコンテンツ」→「新規」→「リスト」で 'Projects' リストを作成",
    "3. 上記の columns 定義に従い列を追加する（Title は既定で存在）",
    "4. 同様に 'WorkHoursLog' リストを作成し列を追加",
    "5. 「新規」→「ドキュメントライブラリ」で 'WorkHoursDashboard' を作成",
    "6. Projects リストに sampleData のプロジェクトを登録",
    "7. Outlook でプロジェクト名と同じカテゴリを作成する（色は自由）",
    "8. Power Automate フローを設定する（flow1-outlook-trigger.md 参照）"
  ]
}
